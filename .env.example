# ----------------------------------------------------------------------------
# Expense Tracker - Environment Variables
# ----------------------------------------------------------------------------
# 1. DATABASE_URL
# To connect your local application to the database deployed on Render,
# you must paste your "External Database URL" from the Render Dashboard here:
# (Go to Render -> PostgreSQL Database -> Connect -> External Database URL)
# Example: postgres://expense_admin:xyz@dpg-xxx-a.oregon-postgres.render.com/expense_manager

DATABASE_URL=

# 2. CEREBRAS_API_KEY
# Used for the AI Chatbot functionality
CEREBRAS_API_KEY=

# 3. GOOGLE OAUTH
# Create credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 4. SESSION SECRET
# Used for signing sessions (required for Authlib/FastAPI Auth)
# Generate a random string: openssl rand -hex 32
SECRET_KEY=